generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  lastName  String?
  rut       String?
  phone     String?
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
}

enum Role {
  ADMIN
  PROFESSIONAL
  CUSTOMER
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?
  duration    Int
  price       Int
  deposit     Int
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  appointments Appointment[]
}

model Appointment {
  id            String   @id @default(cuid())
  date          DateTime
  status        AppointmentStatus @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentRef    String?
  confirmToken  String?
  cancelToken   String?
  notes         String?
  reminderSent  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  @@index([date])
  @@index([userId])
  @@index([status])
  @@index([date, status])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  DEPOSIT_PAID
  FULLY_PAID
  REFUNDED
}

model BusinessSettings {
  id           String  @id @default(cuid())
  name         String  @default("Barbería & Estética")
  address      String?
  phone        String?
  email        String?
  instagram    String?
  mapsEmbedUrl String?

  // Hero
  heroTitle    String?
  heroSubtitle String?
  heroImageUrl String?

  // Sobre mí
  showAbout    Boolean @default(false)
  aboutTitle   String?
  aboutText    String?
  aboutImageUrl String?

  // Video
  showVideo    Boolean @default(false)
  videoUrl     String?
  videoCaption String?

  @@map("business_settings")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  service   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model MediaPost {
  id        String   @id @default(cuid())
  url       String
  embedUrl  String
  platform  String   // "instagram" | "tiktok"
  caption   String?
  isPublic  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("media_posts")
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("gallery_images")
}

model TimeSlot {
  id        String   @id @default(cuid())
  datetime  DateTime @unique
  isBooked  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([datetime, isBooked])
  @@map("time_slots")
}

model BusinessHours {
  id        String  @id @default(cuid())
  weekday   Int     @unique // 0=Domingo, 1=Lunes ... 6=Sabado
  isOpen    Boolean @default(true)
  openTime  String  @default("09:00") // HH:mm
  closeTime String  @default("19:00") // HH:mm

  @@map("business_hours")
}
